{
    "name": "CtrBlock",
    "license": "GPL-3.0",
    "type": "module",
    "packageManager": "pnpm@10.28.2",
    "scripts": {
        "prettier": "prettier . --write",
        "lint": "eslint .",
        "build": "vite build --mode development",
        "build-release": "vite build --mode release",
        "watch": "vite build --mode development --watch",
        "tailwindcss": "tailwindcss -i ./src/app.pcss -o ./dist/assets/tailwind.css",
        "generate-rulesets": "node build/generate-rulesets.js",
        "test:filter": "playwright test --config tests/filter/playwright.config.js",
        "test:youtube": "playwright test --config tests/youtube/playwright.config.js",
        "test:scriptlets": "node --test tests/scriptlets/compare.test.js",
        "test:components": "vitest run"
    },
    "dependencies": {
        "@ctrlblk/ctrlblk-filters": "github:ctrlblk/ctrlblk-filters#v1",
        "date-fns": "^3.3.1",
        "del": "^6.1.0",
        "detect-browser": "^5.3.0",
        "punycode.js": "^2.3.1",
        "semver": "^7.6.0",
        "vite": "^6.4.1"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@samrum/vite-plugin-web-extension": "^5.1.0",
        "@sveltejs/vite-plugin-svelte": "^5.1.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/svelte": "^5.3.1",
        "argparse": "^2.0.1",
        "autoprefixer": "^10.4.16",
        "eslint": "^8.55.0",
        "eslint-config-google": "^0.14.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.0.1",
        "express": "^5.2.1",
        "fast-glob": "^3.3.2",
        "flowbite": "^2.2.1",
        "flowbite-svelte": "^0.46.23",
        "flowbite-svelte-icons": "^2.3.0",
        "jsdom": "^28.1.0",
        "postcss": "^8.4.32",
        "postcss-load-config": "^5.0.2",
        "svelte": "^5.53.7",
        "tailwindcss": "^3.3.6",
        "vitest": "^4.0.18"
    }
}
